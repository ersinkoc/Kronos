# Copy to /etc/kronos/kronos-agent.env and set mode 0640.

KRONOS_SERVER_URL=https://kronos.example.com:8500
KRONOS_AGENT_ID=agent-prod-1
KRONOS_AGENT_CAPACITY=1
KRONOS_TOKEN=replace-with-agent-token
KRONOS_KEY_ID=prod-2026
KRONOS_MANIFEST_PRIVATE_KEY=replace-with-ed25519-private-key-hex
KRONOS_CHUNK_KEY=replace-with-32-byte-hex-key

# Set when the control plane requires TLS or mTLS.
KRONOS_TLS_CERT=/etc/kronos/tls/agent.crt
KRONOS_TLS_KEY=/etc/kronos/tls/agent.key
KRONOS_TLS_CA=/etc/kronos/tls/server-ca.crt
